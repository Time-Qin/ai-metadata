{
  "name": "aigc-metadata",
  "version": "1.0.0",
  "description": "Browser-side AIGC implicit metadata SDK for OOXML/PDF files",
  "type": "module",
  "main": "./dist/aigc-metadata.cjs",
  "module": "./dist/aigc-metadata.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/aigc-metadata.mjs",
      "require": "./dist/aigc-metadata.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "aigc",
    "metadata",
    "ooxml",
    "pdf",
    "docx",
    "pptx",
    "xlsx",
    "browser",
    "sdk"
  ],
  "author": "Time-Qin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Time-Qin/ai-metadata.git"
  },
  "homepage": "https://github.com/Time-Qin/ai-metadata#readme",
  "bugs": {
    "url": "https://github.com/Time-Qin/ai-metadata/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^22.10.0",
    "@xmldom/xmldom": "^0.9.10",
    "happy-dom": "^20.10.6",
    "rollup": "^4.28.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
